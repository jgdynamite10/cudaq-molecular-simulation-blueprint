# cudaq-molecular-simulation-blueprint - environment variables
# Copy to .env and fill in values. Never commit .env.

# --- Application -----------------------------------------------------------

# Where run artifacts are written. Defaults to ./results in the repo root.
CUDAQ_BP_RESULTS_DIR=./results

# Logging level: DEBUG, INFO, WARNING, ERROR. JSON-formatted.
CUDAQ_BP_LOG_LEVEL=INFO

# Default backend for CLI/API when not specified. Values: cpu, gpu_fp32, gpu_fp64
CUDAQ_BP_DEFAULT_BACKEND=cpu

# RNG seed for reproducibility.
CUDAQ_BP_SEED=42

# --- API -------------------------------------------------------------------

CUDAQ_BP_API_HOST=0.0.0.0
CUDAQ_BP_API_PORT=8000

# Optional CORS origins, comma-separated. Empty disables CORS.
CUDAQ_BP_CORS_ORIGINS=

# --- Akamai / Linode (used only by infra/terraform) ------------------------

# Linode personal access token with read/write linodes scope.
LINODE_TOKEN=

# SSH public key string to authorize on the GPU VM.
AKAMAI_SSH_AUTHORIZED_KEY=

# Region slug. Defaults to us-lax in Terraform but can override here.
AKAMAI_REGION=us-lax

# Instance type. Default for the GPU plan in this project.
AKAMAI_INSTANCE_TYPE=g3-gpu-rtxpro6000-blackwell-1
