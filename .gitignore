# Environment
.env
.env.local
*.env

# Results - keep directory but ignore generated artifacts.
# Sample artifacts ship attached to GitHub Releases, not in the tree.
# Lightweight committed summaries live under akamai-blackwell-multiseed/.
results/*
!results/.gitkeep
!results/akamai-blackwell-multiseed/
results/akamai-blackwell-multiseed/*
!results/akamai-blackwell-multiseed/SUMMARY.csv
!results/akamai-blackwell-multiseed/comparison.json
!results/akamai-blackwell-multiseed/README.md

# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
tfplan
*.tfplan

# Ansible
*.retry
infra/ansible/inventory.ini
infra/ansible/*.vault

# Docker
.dockerignore.local

# Logs / run records
*.log
logs/
.runlogs/

# Static UI export (built by `python -m app.ui.static_export`)
_site/

# Generated archives
*.tgz
*.tar.gz
*.zip

# Defensive: never let SSH keys get tracked
*.pem
id_rsa*
id_ed25519*
*-akamai
*-akamai.pub

# Internal handover documents - never publish
PROJECT_STATUS.md
HANDOVER.md
.handover/
